ANTHROPIC_API_KEY=sk-ant-...
# Free at https://tavily.com — 1000 searches/month, no credit card.
# Required for research. Each prospect uses ~4 searches.
TAVILY_API_KEY=tvly-...
# Free at https://neon.tech — 0.5 GB storage, no credit card.
# Optional: enables saved-companies history across redeploys. Without it,
# the history feature gracefully disables; research and drafting still work.
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
